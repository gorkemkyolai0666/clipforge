# ClipForge Backend — Ortam Değişkenleri
# Tam production aktivasyonu için aşağıdaki credential'lar sağlanmalıdır.

# PostgreSQL bağlantı dizesi (Railway otomatik sağlar)
DATABASE_URL=

# JWT imzalama anahtarı (organizasyon Loom Actions secret: JWT_SECRET)
JWT_SECRET=

# Frontend URL (CORS referansı, wildcard CORS aktif)
FRONTEND_URL=https://clipforge.vercel.app

# Backend port (Railway'de 8080, yerelde 5170)
PORT=5170

# ─── Harici Entegrasyon Placeholder'ları (Gelecek Fazlar) ───
# STRIPE_SECRET_KEY=          # Ödeme gateway (kısa vade monetizasyon)
# STRIPE_WEBHOOK_SECRET=      # Stripe webhook doğrulama
# OPENAI_API_KEY=             # AI sprint planlama kredileri (orta vade)
# SMTP_HOST=                  # E-posta bildirimleri
# SMTP_USER=
# SMTP_PASS=
